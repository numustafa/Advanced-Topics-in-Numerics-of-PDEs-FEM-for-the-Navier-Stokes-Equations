{
  "latex-workshop.latex.autoBuild.run": "onSave",
  "latex-workshop.latex.recipe.default": "pdflatex x2",
  "latex-workshop.latex.recipes": [
    {
      "name": "pdflatex x2",
      "tools": [
        "pdflatex",
        "pdflatex"
      ]
    }
  ],
  "latex-workshop.latex.tools": [
    {
      "name": "pdflatex",
      "command": "pdflatex",
      "args": [
        "-interaction=nonstopmode",
        "-halt-on-error",
        "%DOC%"
      ]
    }
  ]
}
